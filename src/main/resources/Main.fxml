<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.shoppingcart.ShoppingCartController"
            prefHeight="500.0" prefWidth="600.0" style="-fx-background-color: #f5f5f5;">
    
    <top>
        <VBox spacing="10" style="-fx-background-color: #2c3e50;">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>
            <Label fx:id="appTitleLabel" text="Shopping Cart Application" style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;"/>
            <Label text="Timo's Shopping Cart" style="-fx-text-fill: #bdc3c7; -fx-font-size: 14;"/>
        </VBox>
    </top>
    
    <center>
        <VBox spacing="15">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <HBox spacing="10" alignment="CENTER_LEFT">
                <padding>
                    <Insets top="0" right="10" bottom="0" left="0"/>
                </padding>
                <Label fx:id="languageLabel" text="Language:" style="-fx-font-weight: bold;"/>
                <ChoiceBox fx:id="languageChoice" onAction="#onLanguageChanged" prefWidth="150"/>
            </HBox>
            
            <Separator/>
            
            <HBox spacing="10" alignment="CENTER_LEFT">
                <padding>
                    <Insets top="0" right="10" bottom="0" left="0"/>
                </padding>
                <Label fx:id="numItemsLabel" text="Enter the number of items to purchase:" style="-fx-font-weight: bold;"/>
                <TextField fx:id="numItemsField" promptText="Enter number" prefWidth="100"/>
                <Button fx:id="createItemsButton" text="Create Items" onAction="#onCreateItems"/>
            </HBox>
            
            <Label fx:id="errorLabel" text="" style="-fx-text-fill: #e74c3c;"/>
            
            <VBox fx:id="itemsContainer" spacing="10">
                <padding>
                    <Insets top="0" right="0" bottom="0" left="0"/>
                </padding>
            </VBox>
            
            <HBox spacing="10">
                <padding>
                    <Insets top="0" right="10" bottom="0" left="0"/>
                </padding>
                <Button fx:id="calculateButton" text="Calculate Total" onAction="#onCalculate" 
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </HBox>
            
            <Separator/>
            
            <HBox spacing="10" alignment="CENTER_LEFT">
                <padding>
                    <Insets top="0" right="10" bottom="0" left="0"/>
                </padding>
                <Label fx:id="totalCostLabel" text="Total cost:" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
                <Label fx:id="totalCostValue" text="0.00" style="-fx-font-size: 18; -fx-text-fill: #e74c3c;"/>
            </HBox>
            
            <VBox fx:id="itemTotalsContainer" spacing="5">
                <padding>
                    <Insets top="0" right="0" bottom="0" left="0"/>
                </padding>
            </VBox>
        </VBox>
    </center>
    
    <bottom>
        <HBox style="-fx-background-color: #34495e;" alignment="CENTER">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
            <Label fx:id="footerLabel" text="SEP2 - Week 2 Assignment - JavaFX Shopping Cart" style="-fx-text-fill: #bdc3c7;"/>
        </HBox>
    </bottom>
</BorderPane>