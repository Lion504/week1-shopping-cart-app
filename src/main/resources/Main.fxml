<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.shoppingcart.ShoppingCartController" 
            prefHeight="500.0" prefWidth="600.0" style="-fx-background-color: #f5f5f5;">
    
    <top>
        <VBox spacing="10" style="-fx-background-color: #2c3e50; -fx-padding: 15;">
            <Label text="%app.title" style="-fx-text-fill: white; -fx-font-size: 24; -fx-font-weight: bold;"/>
            <Label text="Timo's Shopping Cart" style="-fx-text-fill: #bdc3c7; -fx-font-size: 14;"/>
        </VBox>
    </top>
    
    <center>
        <VBox spacing="15" padding="20">
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="%label.language" style="-fx-font-weight: bold;"/>
                <ChoiceBox fx:id="languageChoice" onAction="#onLanguageChanged" prefWidth="150">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="English"/>
                            <String fx:value="Suomi"/>
                            <String fx:value="Svenska"/>
                            <String fx:value="日本語"/>
                            <String fx:value="العربية"/>
                        </FXCollections>
                    </items>
                </ChoiceBox>
            </HBox>
            
            <Separator/>
            
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="%prompt.num.items" style="-fx-font-weight: bold;"/>
                <TextField fx:id="numItemsField" promptText="%prompt.num.items" prefWidth="100"/>
                <Button fx:id="createItemsButton" text="%button.create" onAction="#onCreateItems"/>
            </HBox>
            
            <VBox fx:id="itemsContainer" spacing="10"/>
            
            <HBox spacing="10">
                <Button fx:id="calculateButton" text="%button.calculate" onAction="#onCalculate" 
                        style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold;"/>
            </HBox>
            
            <Separator/>
            
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Label text="%label.total.cost" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
                <Label fx:id="totalCostLabel" text="0.00" style="-fx-font-size: 18; -fx-text-fill: #e74c3c;"/>
            </HBox>
            
            <VBox fx:id="itemTotalsContainer" spacing="5"/>
        </VBox>
    </center>
    
    <bottom>
        <HBox style="-fx-background-color: #34495e; -fx-padding: 10;" alignment="CENTER">
            <Label text="%label.footer" style="-fx-text-fill: #bdc3c7;"/>
        </HBox>
    </bottom>
</BorderPane>